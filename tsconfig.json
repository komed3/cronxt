{
  "compilerOptions": {
    "target": "ESNext",
    "moduleResolution": "bundler",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": [ "ESNext", "ESNext.Intl" ],
    "types": [ "node" ]
  },
  "include": [ "src" ],
  "exclude": [ "node_modules", "dist" ]
}
