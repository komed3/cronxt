{
  "name": "nxtcron",
  "description": "Lightweight, zero-dependency cron expression parser, validator, and scheduler written in TypeScript",
  "license": "MIT",
  "version": "1.0.0",
  "author": {
    "name": "komed3 (Paul Köhler)",
    "email": "webmaster@komed3.de",
    "url": "https://komed3.de"
  },
  "keywords": [
    "cron",
    "cron-parser",
    "scheduler",
    "typescript",
    "zero-dependency",
    "lightweight"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komed3/nxtcron.git"
  },
  "bugs": {
    "url": "https://github.com/komed3/nxtcron/issues"
  },
  "funding": {
    "type": "ko-fi",
    "url": "https://ko-fi.com/komed3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:dts": "tsc -p tsconfig.dts.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:all": "npm run build:cjs && npm run build:dts && npm run build:esm && tsc-alias",
    "format": "prettier --ignore-path \"\" --write \"./dist/**/*.@(js|d.ts)\" --log-level warn",
    "build": "npm run build:all && npm run format",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
